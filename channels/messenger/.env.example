# =============================================
# PICOBOT MESSENGER CONFIGURATION
# =============================================

# Admin Config (Replace with actual values after obtaining appstate)
ADMIN_UID=100037951718438
ADMIN_NAME=Bot Admin

# Bot Identity
BOT_NAME=picobot
BOT_PREFIX=!  # Command prefix for strict mode

# Channel Settings
CHANNEL_NAME=facebook
CHANNEL_ID=messenger_main

# Picobot API Endpoint (where your main server.js runs)
PICOBOT_API=http://localhost:3000/chat
PICOBOT_API_KEY=your_api_key_here  # Optional: for secure communication

# Mode Settings
# MODE: "open" (respond to all), "whitelist" (only whitelist), "admin" (admin only)
MODE=whitelist

# White Mode: When true, bot only responds to whitelisted users
WHITE_MODE=true

# Thread Support
THREAD_MODE=true
THREAD_PREFIX=[Thread]

# Logging
LOG_LEVEL=info  # debug, info, warn, error
LOG_MESSAGES=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MESSAGES=20
RATE_LIMIT_WINDOW=60000  # ms (1 minute)

# Auto-reactions (optional)
AUTO_REACT=true
WELCOME_MESSAGE=true

# Webhook/Callback URL (optional - for receiving updates)
# WEBHOOK_URL=https://your-server.com/webhook
